{%- assign redirect_url = section.settings.redirect_url -%}

{% if redirect_url != blank %}
  <meta http-equiv="refresh" content="0;url={{ redirect_url }}">
  <script>window.location.replace("{{ redirect_url }}");</script>
{% endif %}

<noscript>
  {% if redirect_url != blank %}
    <meta http-equiv="refresh" content="0;url={{ redirect_url }}">
  {% endif %}
</noscript>

{% schema %}
{
  "name": "Page Redirect",
  "settings": [
    {
      "type": "url",
      "id": "redirect_url",
      "label": "Redirect URL"
    }
  ],
  "presets": [
    { "name": "Page Redirect" }
  ]
}
{% endschema %}
