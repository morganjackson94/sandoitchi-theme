{
  "name": "Header Minimal",
  "settings": [
    { "type": "image_picker", "id": "hero_variant_1",  "label": "Hero Variant 1" },
    { "type": "image_picker", "id": "hero_variant_2",  "label": "Hero Variant 2" },
    { "type": "image_picker", "id": "hero_variant_3",  "label": "Hero Variant 3" },
    { "type": "image_picker", "id": "hero_variant_4",  "label": "Hero Variant 4" },
    { "type": "image_picker", "id": "hero_variant_5",  "label": "Hero Variant 5" },
    { "type": "image_picker", "id": "hero_variant_6",  "label": "Hero Variant 6" },
    { "type": "image_picker", "id": "hero_variant_7",  "label": "Hero Variant 7" },
    { "type": "image_picker", "id": "hero_variant_8",  "label": "Hero Variant 8" },
    { "type": "image_picker", "id": "hero_variant_9",  "label": "Hero Variant 9" },
    { "type": "image_picker", "id": "hero_variant_10", "label": "Hero Variant 10" },
    { "type": "image_picker", "id": "hero_variant_11", "label": "Hero Variant 11" },
    { "type": "image_picker", "id": "hero_variant_12", "label": "Hero Variant 12" },
    { "type": "image_picker", "id": "hero_variant_13", "label": "Hero Variant 13" },
    { "type": "image_picker", "id": "hero_variant_14", "label": "Hero Variant 14" },
    { "type": "link_list", "id": "menu", "label": "Menu" },
