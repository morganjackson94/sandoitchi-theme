  <!-- Sticky header emblem shrink: scroll state -->
  <script>
    (function () {
      function getY() {
        return window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0;
      }

      function apply() {
        document.body.classList.toggle('is-scrolled', getY() > 0);
      }

      function start() {
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            apply();
            window.addEventListener('scroll', apply, { passive: true });
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', start, { once: true });
      } else {
        start();
      }
    })();
  </script>

  <!-- Hero title: random variant on refresh -->
  <script>
(function () {
  function pickRandomHeroVariant() {
    var img = document.querySelector('.header-title');
    if (!img) return;

    var list = img.getAttribute('data-variants') || '';
    var variants = list
      .split('|')
      .map(function (s) { return s.trim(); })
      .filter(Boolean);

    if (variants.length < 2) return;

    var choice = variants[Math.floor(Math.random() * variants.length)];

    if (img.src !== choice) {
      img.src = choice;
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', pickRandomHeroVariant);
  } else {
    pickRandomHeroVariant();
  }
})();
</script>


  <!-- Section reveal on first viewport entry (opt-in) -->
  <script>
    (function () {
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('[data-reveal]').forEach(function (el) {
          el.classList.add('is-visible');
        });
        return;
      }

      if (!('IntersectionObserver' in window)) {
        document.querySelectorAll('[data-reveal]').forEach(function (el) {
          el.classList.add('is-visible');
        });
        return;
      }

      var els = document.querySelectorAll('[data-reveal]');
      if (!els.length) return;

      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, {
        root: null,
        threshold: 0.12,
        rootMargin: '0px 0px -8% 0px'
      });

      els.forEach(function (el) {
        io.observe(el);
      });
    })();
  </script>

  <!-- Page fade: remove white veil on load -->
  <script>
    (function () {
      function markLoaded() { document.documentElement.classList.add('is-loaded'); }
      if (document.readyState === 'complete') markLoaded();
      else window.addEventListener('load', markLoaded, { once: true });
    })();
  </script>

<!-- ── Notify Me Modal ── -->
<div id="notify-modal" class="notify-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="notify-modal-title">
  <div class="notify-modal__backdrop"></div>
  <div class="notify-modal__dialog">
    <div class="notify-modal__header">
      <span class="notify-modal__header-label">NOTIFY ME</span>
      <button class="notify-modal__close" type="button" aria-label="Close">&#x2715;</button>
    </div>
    <div class="notify-modal__body">
      <p class="notify-modal__sub">Enter your information and we will notify you when the item becomes available.</p>

      <form class="notify-modal__form" id="NotifyModalForm" action="/contact#contact_form" method="post" target="notify-iframe">
        <input type="hidden" name="form_type" value="contact">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[subject]" value="notify-me">
        <input type="hidden" name="contact[body]" value="[notify-me] Please notify me when this item becomes available.">

        <div class="notify-modal__field-wrap">
          <div class="notify-modal__field-row">
            <label class="notify-modal__label" for="NotifyModalEmail">Email *</label>
            <span class="notify-modal__required">*required fields</span>
          </div>
          <input
            type="email"
            name="contact[email]"
            autocomplete="email"
            required
            class="notify-modal__input"
            id="NotifyModalEmail"
          >
        </div>

        <label class="notify-modal__checkbox-wrap">
          <input type="checkbox" class="notify-modal__checkbox" name="contact[consent]" value="yes" checked>
          <span class="notify-modal__checkbox-label">With your consent, Sandoitchi will use your contact information (E-mail address) to alert you of the product availability.</span>
        </label>

        <label class="notify-modal__checkbox-wrap">
          <input type="checkbox" class="notify-modal__checkbox" name="contact[marketing]" value="yes">
          <span class="notify-modal__checkbox-label">I agree to stay in touch with Sandoitchi</span>
        </label>

        <p class="notify-modal__success" aria-live="polite" hidden>you're on the list ✦</p>
        <p class="notify-modal__error" aria-live="polite" hidden>something went wrong — try again.</p>

        <button type="submit" class="notify-modal__submit">notify me</button>
      </form>
    </div>
  </div>
</div>
<iframe name="notify-iframe" id="notify-iframe" style="display:none" aria-hidden="true"></iframe>

<script>
(function () {
  var modal   = document.getElementById('notify-modal');
  if (!modal) return;

  var form    = document.getElementById('NotifyModalForm');
  var success = modal.querySelector('.notify-modal__success');
  var error   = modal.querySelector('.notify-modal__error');
  var input   = document.getElementById('NotifyModalEmail');

  function openModal() {
    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('is-open');
    document.body.classList.add('notify-modal-open');
    setTimeout(function () { if (input) input.focus(); }, 80);
  }

  function closeModal() {
    modal.setAttribute('aria-hidden', 'true');
    modal.classList.remove('is-open');
    document.body.classList.remove('notify-modal-open');
    if (success) success.hidden = true;
    if (error)   error.hidden   = true;
    if (form)    form.reset();
    var submitBtn = form ? form.querySelector('.notify-modal__submit') : null;
    if (submitBtn) submitBtn.hidden = false;
    var fieldWrap = form ? form.querySelector('.notify-modal__field-wrap') : null;
    if (fieldWrap) fieldWrap.style.display = '';
  }

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-notify]');
    if (btn) { e.preventDefault(); openModal(); }
  });

  modal.querySelector('.notify-modal__backdrop').addEventListener('click', closeModal);
  modal.querySelector('.notify-modal__close').addEventListener('click', closeModal);
  document.addEventListener('keydown', function (e) {
    if ((e.key === 'Escape' || e.keyCode === 27) && modal.classList.contains('is-open')) closeModal();
  });

  if (form) {
    // Submit into hidden iframe — avoids page navigation, works reliably with Shopify /contact
    var iframe = document.getElementById('notify-iframe');

    form.addEventListener('submit', function (e) {
      var email = input ? input.value.trim() : '';
      if (!email) { e.preventDefault(); return; }

      var submitBtn = form.querySelector('.notify-modal__submit');
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'sending...'; }

      // Let the form submit natively into the iframe
      // Listen for iframe load as success signal
      if (iframe) {
        iframe.onload = function () {
          if (success) success.hidden = false;
          if (error)   error.hidden   = true;
          var fieldWrap = form.querySelector('.notify-modal__field-wrap');
          if (fieldWrap) fieldWrap.style.display = 'none';
          var checkboxes = form.querySelectorAll('.notify-modal__checkbox-wrap');
          checkboxes.forEach(function(c){ c.style.display = 'none'; });
          if (submitBtn) submitBtn.hidden = true;
          iframe.onload = null;
        };
      }
      // Form submits natively — don't preventDefault
    });
  }
})();
</script>

<script>
/* ── Scroll reveal: fade-up sections, stagger grids ── */
(function () {
  if (!window.IntersectionObserver) return;

  var STAGGER_STEP = 80;   /* ms between each staggered child */
  var STAGGER_CAP  = 8;    /* max stagger index (640ms) */

  var GRID_SELECTORS = '.shop-grid, .locations-grid__list, .menu-grid';

  function inViewport(el) {
    var r = el.getBoundingClientRect();
    return r.top < window.innerHeight && r.bottom > 0;
  }

  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (!entry.isIntersecting) return;
      entry.target.classList.add('sr-visible');
      observer.unobserve(entry.target);
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  /* Stagger grid children */
  document.querySelectorAll(GRID_SELECTORS).forEach(function (container) {
    if (inViewport(container)) return;
    Array.from(container.children).forEach(function (child, i) {
      child.classList.add('sr-stagger');
      child.style.setProperty('--sr-i', Math.min(i, STAGGER_CAP));
    });
    container.classList.add('sr-group');
    observer.observe(container);
  });

  /* Fade-up remaining section roots */
  document.querySelectorAll('.shopify-section > *').forEach(function (el) {
    if (inViewport(el)) return;
    if (el.matches(GRID_SELECTORS) || el.querySelector(GRID_SELECTORS)) return;
    if (window.getComputedStyle(el).position === 'fixed') return;
    if (el.getBoundingClientRect().height === 0) return;
    el.classList.add('sr-fade');
    observer.observe(el);
  });
})();
</script>

</body>
